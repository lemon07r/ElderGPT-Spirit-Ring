{
  "name": "afnm-eldergpt-spirit-ring",
  "version": "0.6.0",
  "description": "AI-powered contextual chat assistant mod for Ascend From Nine Mountains",
  "author": {
    "name": "Lamim"
  },
  "main": "dist/afnm-eldergpt-spirit-ring/mod.js",
  "scripts": {
    "prebuild": "rm -rf dist/afnm-eldergpt-spirit-ring",
    "build": "bun run webpack --mode production",
    "postbuild": "bun scripts/zip-dist.js",
    "workshop:preview": "bun run scripts/generate-workshop-preview.js",
    "workshop:upload": "bun run scripts/workshop-upload.ts",
    "release:validate": "bun run test && bun run build && bun run runtime:oracle && bun run docs:check",
    "test": "bun run jest",
    "test:watch": "bun run jest --watch",
    "test:coverage": "bun run jest --coverage",
    "ui:harness:build": "mkdir -p tmp/ui-harness && cp scripts/ui/agent-browser-harness.html tmp/ui-harness/index.html && bun build scripts/ui/agent-browser-harness.tsx --outfile tmp/ui-harness/eldergpt-ui-harness.js --target browser --format esm",
    "ui:harness:serve": "python3 -m http.server 4173 --directory tmp/ui-harness",
    "runtime:oracle": "node scripts/installed-game-runtime.js summary",
    "runtime:extract": "node scripts/installed-game-runtime.js extract",
    "runtime:grep": "node scripts/installed-game-runtime.js grep",
    "docs:check-links": "bun run scripts/docs/check-links.js",
    "docs:check-freshness": "bun run scripts/docs/check-freshness.js",
    "docs:check-authority": "bun run scripts/docs/check-authority.js",
    "docs:check": "bun run docs:check-links && bun run docs:check-freshness && bun run docs:check-authority",
    "docs:inventory": "bun run scripts/docs/generate-inventory.js"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react-dom": "^19.2.3",
    "afnm-types": "0.6.50",
    "file-loader": "^6.2.0",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "zip-a-folder": "^4.0.4"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0"
  }
}
